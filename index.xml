      <description>&lt;div class=&#34;world-population-page&#34;&gt;&#xA;&#x9;&lt;style&gt;&#xA;&#x9;&#x9;.world-population-page {&#xA;&#x9;&#x9;&#x9;display: grid;&#xA;&#x9;&#x9;&#x9;gap: 1rem;&#xA;&#x9;&#x9;&#x9;color: var(--project-ink, #f4efe6);&#xA;&#x9;&#x9;}&#xA;&#xA;&#x9;&#x9;.world-population-panel,&#xA;&#x9;&#x9;.world-population-stage {&#xA;&#x9;&#x9;&#x9;border: 1px solid rgba(151, 31, 22, 0.44);&#xA;&#x9;&#x9;&#x9;border-radius: 4px;&#xA;&#x9;&#x9;&#x9;background: #111;&#xA;&#x9;&#x9;&#x9;box-shadow: 0 1.25rem 2.8rem rgba(0, 0, 0, 0.36);&#xA;&#x9;&#x9;}&#xA;&#xA;&#x9;&#x9;.world-population-panel {&#xA;&#x9;&#x9;&#x9;display: grid;&#xA;&#x9;&#x9;&#x9;gap: 0.9rem;&#xA;&#x9;&#x9;&#x9;padding: 1rem;&#xA;&#x9;&#x9;}&#xA;&#xA;&#x9;&#x9;.world-population-panel h2,&#xA;&#x9;&#x9;.world-population-panel p {&#xA;&#x9;&#x9;&#x9;margin: 0;&#xA;&#x9;&#x9;}&#xA;&#xA;&#x9;&#x9;.world-population-panel p,&#xA;&#x9;&#x9;.world-population-status {&#xA;&#x9;&#x9;&#x9;color: var(--project-muted, #c7b9a3);&#xA;&#x9;&#x9;}&#xA;&#xA;&#x9;&#x9;.world-population-toolbar,&#xA;&#x9;&#x9;.world-population-metric,&#xA;&#x9;&#x9;.world-population-scale,&#xA;&#x9;&#x9;.world-population-visibility,&#xA;&#x9;&#x9;.world-population-comparison,&#xA;&#x9;&#x9;.world-population-continents,&#xA;&#x9;&#x9;.world-population-legend,&#xA;&#x9;&#x9;.world-population-highlight {&#xA;&#x9;&#x9;&#x9;display: flex;&#xA;&#x9;&#x9;&#x9;flex-wrap: wrap;&#xA;&#x9;&#x9;&#x9;gap: 0.75rem;&#xA;&#x9;&#x9;&#x9;align-items: center;&#xA;&#x9;&#x9;}&#xA;&#xA;&#x9;&#x9;.world-population-field {&#xA;&#x9;&#x9;&#x9;display: grid;&#xA;&#x9;&#x9;&#x9;gap: 0.35rem;&#xA;&#x9;&#x9;&#x9;flex: 1 1 18rem;&#xA;&#x9;&#x9;}&#xA;&#xA;&#x9;&#x9;.world-population-slider {&#xA;&#x9;&#x9;&#x9;display: grid;&#xA;&#x9;&#x9;&#x9;gap: 0.35rem;&#xA;&#x9;&#x9;&#x9;flex: 1 1 14rem;&#xA;&#x9;&#x9;}&#xA;&#xA;&#x9;&#x9;.world-population-field input {&#xA;&#x9;&#x9;&#x9;border: 1px solid rgba(151, 31, 22, 0.44);&#xA;&#x9;&#x9;&#x9;border-radius: 4px;&#xA;&#x9;&#x9;&#x9;padding: 0.6rem 0.75rem;&#xA;&#x9;&#x9;&#x9;font: inherit;&#xA;&#x9;&#x9;&#x9;background: #090909;&#xA;&#x9;&#x9;&#x9;color: var(--project-ink, #f4efe6);&#xA;&#x9;&#x9;}&#xA;&#xA;&#x9;&#x9;.world-population-slider input[type=&#34;range&#34;] {&#xA;&#x9;&#x9;&#x9;accent-color: var(--project-red-2, #c43b2f);&#xA;&#x9;&#x9;}&#xA;&#xA;&#x9;&#x9;.world-population-chip {&#xA;&#x9;&#x9;&#x9;display: inline-flex;&#xA;&#x9;&#x9;&#x9;align-items: stretch;&#xA;&#x9;&#x9;&#x9;border: 1px solid rgba(151, 31, 22, 0.44);&#xA;&#x9;&#x9;&#x9;border-radius: 999px;&#xA;&#x9;&#x9;&#x9;background: #111;&#xA;&#x9;&#x9;&#x9;color: var(--project-ink, #f4efe6);&#xA;&#x9;&#x9;&#x9;overflow: hidden;&#xA;&#x9;&#x9;}&#xA;&#xA;&#x9;&#x9;.world-population-chip.is-selected {&#xA;&#x9;&#x9;&#x9;border-color: var(--project-red-2, #c43b2f);&#xA;&#x9;&#x9;&#x9;background: rgba(151, 31, 22, 0.3);&#xA;&#x9;&#x9;&#x9;box-shadow: inset 0 0 0 1px var(--project-red-2, #c43b2f);&#xA;&#x9;&#x9;&#x9;font-weight: 700;&#xA;&#x9;&#x9;}&#xA;&#xA;&#x9;&#x9;.world-population-chip-swatch {&#xA;&#x9;&#x9;&#x9;width: 0.8rem;&#xA;&#x9;&#x9;&#x9;height: 0.8rem;&#xA;&#x9;&#x9;&#x9;border-radius: 999px;&#xA;&#x9;&#x9;&#x9;flex: 0 0 auto;&#xA;&#x9;&#x9;}&#xA;&#xA;&#x9;&#x9;.world-population-chip-label,&#xA;&#x9;&#x9;.world-population-chip-remove {&#xA;&#x9;&#x9;&#x9;border: 0;&#xA;&#x9;&#x9;&#x9;background: transparent;&#xA;&#x9;&#x9;&#x9;color: inherit;&#xA;&#x9;&#x9;&#x9;font: inherit;&#xA;&#x9;&#x9;}&#xA;&#xA;&#x9;&#x9;.world-population-chip-label {&#xA;&#x9;&#x9;&#x9;display: inline-flex;&#xA;&#x9;&#x9;&#x9;align-items: center;&#xA;&#x9;&#x9;&#x9;gap: 0.55rem;&#xA;&#x9;&#x9;&#x9;padding: 0.35rem 0.35rem 0.35rem 0.7rem;&#xA;&#x9;&#x9;&#x9;cursor: pointer;&#xA;&#x9;&#x9;}&#xA;&#xA;&#x9;&#x9;.world-population-chip-remove {&#xA;&#x9;&#x9;&#x9;display: inline-flex;&#xA;&#x9;&#x9;&#x9;align-items: center;&#xA;&#x9;&#x9;&#x9;justify-content: center;&#xA;&#x9;&#x9;&#x9;min-width: 2rem;&#xA;&#x9;&#x9;&#x9;padding: 0 0.6rem 0 0.35rem;&#xA;&#x9;&#x9;&#x9;cursor: pointer;&#xA;&#x9;&#x9;&#x9;border-left: 1px solid rgba(201, 163, 106, 0.18);&#xA;&#x9;&#x9;&#x9;font-size: 0.95rem;&#xA;&#x9;&#x9;&#x9;line-height: 1;&#xA;&#x9;&#x9;}&#xA;&#xA;&#x9;&#x9;.world-population-chip-remove:hover,&#xA;&#x9;&#x9;.world-population-chip-label:hover {&#xA;&#x9;&#x9;&#x9;background: rgba(151, 31, 22, 0.22);&#xA;&#x9;&#x9;}&#xA;&#xA;&#x9;&#x9;.world-population-metric button.is-active,&#xA;&#x9;&#x9;.world-population-scale button.is-active {&#xA;&#x9;&#x9;&#x9;box-shadow: inset 0 0 0 1px var(--project-red-2, #c43b2f);&#xA;&#x9;&#x9;&#x9;background: rgba(151, 31, 22, 0.3);&#xA;&#x9;&#x9;&#x9;color: #fff8ed;&#xA;&#x9;&#x9;}&#xA;&#xA;&#x9;&#x9;.world-population-scale button:disabled {&#xA;&#x9;&#x9;&#x9;opacity: 0.55;&#xA;&#x9;&#x9;&#x9;cursor: not-allowed;&#xA;&#x9;&#x9;}&#xA;&#xA;&#x9;&#x9;.world-population-continents button.is-active {&#xA;&#x9;&#x9;&#x9;box-shadow: inset 0 0 0 1px var(--project-red-2, #c43b2f);&#xA;&#x9;&#x9;&#x9;background: var(--continent-button-bg, rgba(151, 31, 22, 0.3));&#xA;&#x9;&#x9;&#x9;color: var(--continent-button-fg, #fff8ed);&#xA;&#x9;&#x9;}&#xA;&#xA;&#x9;&#x9;.world-population-stage {&#xA;&#x9;&#x9;&#x9;position: relative;&#xA;&#x9;&#x9;&#x9;padding: 0.75rem;&#xA;&#x9;&#x9;}&#xA;&#xA;&#x9;&#x9;#world-population-chart {&#xA;&#x9;&#x9;&#x9;width: 100%;&#xA;&#x9;&#x9;&#x9;min-height: 34rem;&#xA;&#x9;&#x9;}&#xA;&#xA;&#x9;&#x9;.world-population-tooltip {&#xA;&#x9;&#x9;&#x9;position: absolute;&#xA;&#x9;&#x9;&#x9;display: none;&#xA;&#x9;&#x9;&#x9;pointer-events: none;&#xA;&#x9;&#x9;&#x9;max-width: 16rem;&#xA;&#x9;&#x9;&#x9;padding: 0.6rem 0.75rem;&#xA;&#x9;&#x9;&#x9;border: 1px solid var(--project-red-2, #c43b2f);&#xA;&#x9;&#x9;&#x9;border-radius: 4px;&#xA;&#x9;&#x9;&#x9;background: rgba(8, 8, 8, 0.97);&#xA;&#x9;&#x9;&#x9;color: var(--project-ink, #f4efe6);&#xA;&#x9;&#x9;&#x9;box-shadow: 0 1rem 2rem rgba(0, 0, 0, 0.48);&#xA;&#x9;&#x9;&#x9;font-size: 0.9rem;&#xA;&#x9;&#x9;&#x9;line-height: 1.4;&#xA;&#x9;&#x9;&#x9;z-index: 2;&#xA;&#x9;&#x9;}&#xA;&#xA;&#x9;&#x9;.world-population-tooltip strong {&#xA;&#x9;&#x9;&#x9;display: block;&#xA;&#x9;&#x9;&#x9;margin-bottom: 0.2rem;&#xA;&#x9;&#x9;&#x9;color: #fff8ed;&#xA;&#x9;&#x9;}&#xA;&#xA;&#x9;&#x9;.world-population-note {&#xA;&#x9;&#x9;&#x9;font-size: 0.92rem;&#xA;&#x9;&#x9;}&#xA;&#xA;&#x9;&#x9;@media (max-width: 719px) {&#xA;&#x9;&#x9;&#x9;#world-population-chart {&#xA;&#x9;&#x9;&#x9;&#x9;min-height: 26rem;&#xA;&#x9;&#x9;&#x9;}&#xA;&#x9;&#x9;}&#xA;&#x9;&lt;/style&gt;&#xA;&#x9;&lt;link rel=&#34;stylesheet&#34; href=&#34;https://tbataafschebroederschap.nl/styles/project-theme.css&#34; /&gt;&#xA;&#xA;&#x9;&lt;div class=&#34;world-population-panel&#34;&gt;&#xA;&#x9;&#x9;&lt;h2&gt;Alle landen door de tijd&lt;/h2&gt;&#xA;&#x9;&#x9;&lt;p&gt;Deze grafiek tekent elk land en afhankelijk gebied in de dataset over de volledige historische en geraamde tijdlijn. Alle reeksen blijven op de achtergrond zichtbaar; gemarkeerde landen worden bovenop getekend zodat de grafiek leesbaar blijft.&lt;/p&gt;</description>
